  "case3_deep_extras_4plus_depth": {
    "description": "4+ depth: Incidents with deep optional resolution.timeline.escalation",
    "before": {
      "incidents": [
        { "id": "INC-001", "title": "Login page 500 error", "severity": "critical", "createdAt": "2025-03-15T08:00:00Z" },
        { "id": "INC-002", "title": "Slow dashboard load", "severity": "major", "createdAt": "2025-03-15T09:00:00Z", "resolution": { "assignee": "alice@example.com", "timeline": { "startedAt": "2025-03-15T09:30:00Z", "resolvedAt": "2025-03-15T11:00:00Z", "escalation": { "level": 2, "approvedBy": "bob@example.com", "notes": "Required DB team involvement" } } } },
        { "id": "INC-003", "title": "Payment timeout", "severity": "critical", "createdAt": "2025-03-15T10:00:00Z", "resolution": { "assignee": "charlie@example.com", "timeline": { "startedAt": "2025-03-15T10:15:00Z", "resolvedAt": "2025-03-15T12:00:00Z" } } },
        { "id": "INC-004", "title": "CSS broken on mobile", "severity": "minor", "createdAt": "2025-03-15T11:00:00Z" },
        { "id": "INC-005", "title": "API rate limit hit", "severity": "major", "createdAt": "2025-03-15T12:00:00Z", "resolution": { "assignee": "diana@example.com", "timeline": { "startedAt": "2025-03-15T12:30:00Z", "resolvedAt": "2025-03-15T14:00:00Z", "escalation": { "level": 3, "approvedBy": "eve@example.com", "notes": "Infra scaling required" } } } }
      ]
    },
    "after": {
      "incidents": [
        { "id": "INC-001", "title": "Login page 500 error", "severity": "critical", "createdAt": "2025-03-15T08:00:00Z" },
        { "id": "INC-002", "title": "Slow dashboard load", "severity": "major", "createdAt": "2025-03-15T09:00:00Z" },
        { "id": "INC-003", "title": "Payment timeout", "severity": "critical", "createdAt": "2025-03-15T10:00:00Z" },
        { "id": "INC-004", "title": "CSS broken on mobile", "severity": "minor", "createdAt": "2025-03-15T11:00:00Z" },
        { "id": "INC-005", "title": "API rate limit hit", "severity": "major", "createdAt": "2025-03-15T12:00:00Z" }
      ],
      "incidents.resolution": [
        { "idx": 1, "assignee": "alice@example.com", "timeline.startedAt": "2025-03-15T09:30:00Z", "timeline.resolvedAt": "2025-03-15T11:00:00Z", "timeline.escalation.level": 2, "timeline.escalation.approvedBy": "bob@example.com", "timeline.escalation.notes": "Required DB team involvement" },
        { "idx": 2, "assignee": "charlie@example.com", "timeline.startedAt": "2025-03-15T10:15:00Z", "timeline.resolvedAt": "2025-03-15T12:00:00Z", "timeline.escalation.level": null, "timeline.escalation.approvedBy": null, "timeline.escalation.notes": null },
        { "idx": 4, "assignee": "diana@example.com", "timeline.startedAt": "2025-03-15T12:30:00Z", "timeline.resolvedAt": "2025-03-15T14:00:00Z", "timeline.escalation.level": 3, "timeline.escalation.approvedBy": "eve@example.com", "timeline.escalation.notes": "Infra scaling required" }
      ]
    },
    "notes": {
      "resolution": "3/5 = 60% — threshold 이상, 순이익 양수 → 분리",
      "flatten_depth": "resolution → assignee (1), timeline.startedAt (2), timeline.escalation.level (3) — maxFlattenDepth=3 이내",
      "null_padding": "escalation이 없는 INC-003은 timeline.escalation.* 필드가 null로 패딩"
    }
  },

  "case4_beyond_max_depth": {
    "description": "maxFlattenDepth 초과 시 JSON string 직렬화 fallback",
    "before": {
      "tasks": [
        { "id": "T-001", "name": "Deploy v2", "status": "done" },
        { "id": "T-002", "name": "Fix auth bug", "status": "in-progress", "metadata": { "context": { "environment": { "region": "ap-northeast-2", "cluster": { "name": "prod-1", "nodes": 5 } }, "requester": "ops-team" }, "tags": ["urgent", "security"] } },
        { "id": "T-003", "name": "Update docs", "status": "todo" },
        { "id": "T-004", "name": "Scale DB", "status": "in-progress", "metadata": { "context": { "environment": { "region": "us-east-1", "cluster": { "name": "prod-2", "nodes": 12 } }, "requester": "infra-team" }, "tags": ["infra", "scaling"] } }
      ]
    },
    "after_maxDepth3": {
      "tasks": [
        { "id": "T-001", "name": "Deploy v2", "status": "done" },
        { "id": "T-002", "name": "Fix auth bug", "status": "in-progress" },
        { "id": "T-003", "name": "Update docs", "status": "todo" },
        { "id": "T-004", "name": "Scale DB", "status": "in-progress" }
      ],
      "tasks.metadata": [
        { "idx": 1, "context.environment.region": "ap-northeast-2", "context.environment.cluster": "{\"name\":\"prod-1\",\"nodes\":5}", "context.requester": "ops-team", "tags": "[\"urgent\",\"security\"]" },
        { "idx": 3, "context.environment.region": "us-east-1", "context.environment.cluster": "{\"name\":\"prod-2\",\"nodes\":12}", "context.requester": "infra-team", "tags": "[\"infra\",\"scaling\"]" }
      ]
    },
    "notes": {
      "cluster_serialized": "context.environment.cluster는 depth 4 → maxFlattenDepth=3 초과 → JSON string으로 직렬화",
      "tags_serialized": "tags는 배열 → JSON string으로 직렬화",
      "region_flattened": "context.environment.region은 depth 3 → 정상 flatten"
    }
  },

